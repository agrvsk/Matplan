@using Matplan.Blazor.Client.Services
@inject ILookupService myLookup;

<div class="offcanvas offcanvas-start" tabindex="-1" id="@PanelId">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">@Title</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body">
        @ChildContent
    </div>


</div>

@code 
{
    [Parameter] public string PanelId { get; set; } = "filterPanel";
    [Parameter] public string Title { get; set; } = "Urvalskriterier";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}