@using Matplan.Shared.EntityDtos

<div class="container my-4">

	<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">

	@foreach (var art in Artiklar!)
	{
		<div class="col">
			<div class="card h-100">
				<div class="card-body">
					<h5 class="card-title">@art.ART_ArtikelNamn</h5>
				</div>
			</div>
		</div>
	}

	</div>

</div>

@code {
	[Parameter] public List<ArtikelDto>? Artiklar { get; set; }

}
